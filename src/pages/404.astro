---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Lost in the wilds">
  <section class="wrap notfound">
    <p class="eyebrow">404</p>
    <h1>You've wandered off the map</h1>
    <p>That path doesn't lead anywhere — but the world is full of others.</p>
    <p><a href="/#series">↩ Back to the series</a></p>
  </section>
  <style>
    .notfound { text-align: center; padding: 5rem 0; }
  </style>
</BaseLayout>
