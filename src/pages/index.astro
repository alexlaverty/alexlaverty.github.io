---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SeriesList from '../components/SeriesList.astro';
import { getCategories } from '../utils';
import { SITE_TAGLINE } from '../consts';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const liveSlugs = posts.map((p) => p.id);
const categories = await getCategories();
---

<BaseLayout>
  <!-- Golden-hour hero -->
  <section class="hero">
    <div class="hero-sky" aria-hidden="true"></div>
    <div class="hero-hills" aria-hidden="true"></div>
    <div class="wrap hero-content">
      <p class="eyebrow">Personal site</p>
      <h1>Alex Laverty</h1>
      <p class="hero-tagline">{SITE_TAGLINE}</p>
      <div class="hero-actions">
        <a class="btn" href="#series">Procedural worlds series</a>
        <a class="btn btn-ghost" href="/categories/">Browse categories</a>
      </div>
    </div>
  </section>

  <!-- Browse by category -->
  <section class="wrap cats">
    <h2>Categories</h2>
    <div class="cat-strip">
      {
        categories.map((c) => (
          <a class="cat-chip" href={`/categories/${c.slug}/`}>
            {c.name} <span class="cat-chip-n">{c.count}</span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Featured series -->
  <section id="series" class="wrap series-wrap">
    <p class="eyebrow">Featured series</p>
    <h2>Procedural Worlds in Godot</h2>
    <p class="series-intro">
      Building a procedurally generated VR world for the Meta Quest 2, taken apart
      one system at a time — terrain, rivers, biomes, creatures, light and sound.
    </p>
    <SeriesList liveSlugs={liveSlugs} />
  </section>

  <style>
    .hero {
      position: relative;
      overflow: hidden;
      padding: 5rem 0 6rem;
      text-align: center;
      isolation: isolate;
    }
    .hero-sky {
      position: absolute;
      inset: 0;
      z-index: -2;
      background: linear-gradient(
        180deg,
        #f6d68a 0%,
        #f3b86a 32%,
        #e6917a 60%,
        #8a6f9e 100%
      );
    }
    .hero-sky::after {
      content: '';
      position: absolute;
      left: 50%;
      bottom: 12%;
      width: 320px;
      height: 320px;
      transform: translateX(-50%);
      background: radial-gradient(circle, rgba(255, 248, 224, 0.95), rgba(255, 220, 150, 0) 65%);
    }
    .hero-hills {
      position: absolute;
      inset: auto 0 0 0;
      height: 120px;
      z-index: -1;
      background:
        radial-gradient(120% 100% at 20% 100%, #5f7a55 60%, transparent 61%),
        radial-gradient(120% 100% at 80% 100%, #4e6b4a 60%, transparent 61%);
      opacity: 0.9;
    }
    .hero-content { position: relative; }
    .hero h1 { margin: 0.4rem 0 0.6rem; color: #36230f; }
    .hero-tagline {
      max-width: 34rem;
      margin: 0 auto 1.8rem;
      font-size: 1.15rem;
      color: #4a3522;
    }
    .hero-actions { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; }
    .btn {
      display: inline-block;
      padding: 0.7rem 1.4rem;
      border-radius: 999px;
      font-weight: 600;
      text-decoration: none;
      background: #36230f;
      color: #fbe6c8;
      border: 1px solid #36230f;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .btn:hover { transform: translateY(-2px); box-shadow: var(--shadow); color: #fff; }
    .btn-ghost {
      background: rgba(255, 255, 255, 0.35);
      color: #36230f;
      border-color: rgba(54, 35, 15, 0.4);
    }
    .btn-ghost:hover { color: #36230f; }

    .cats { margin-top: 3rem; }
    .cat-strip { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }
    .cat-chip {
      display: inline-flex;
      gap: 0.4rem;
      align-items: center;
      padding: 0.45rem 0.95rem;
      border-radius: 999px;
      background: var(--paper-raised);
      border: 1px solid var(--line);
      color: var(--ink);
      text-decoration: none;
      font-weight: 500;
      transition: transform 0.15s ease, border-color 0.15s ease;
    }
    .cat-chip:hover { transform: translateY(-2px); border-color: var(--sun); color: var(--ink); }
    .cat-chip-n { color: var(--ink-faint); font-size: 0.82rem; }

    .series-wrap { margin-top: 3.5rem; }
    .series-intro { color: var(--ink-soft); margin-top: -0.2rem; margin-bottom: 2rem; max-width: 42rem; }
  </style>
</BaseLayout>
