---
import { SERIES } from '../series';

interface Props {
  // Slugs that have a published post; everything else shows as "coming soon".
  liveSlugs: string[];
  // Optionally hide a given post from the list (e.g. the hub linking itself).
  hideSlug?: string;
}

const { liveSlugs, hideSlug } = Astro.props;
const live = new Set(liveSlugs);
---

<div class="series">
  {
    SERIES.map((group) => (
      <section class="series-group">
        <h3 class="series-section">{group.section}</h3>
        <ol class="series-items">
          {group.items
            .filter((item) => item.slug !== hideSlug)
            .map((item) => {
              const isLive = live.has(item.slug);
              const Tag = isLive ? 'a' : 'div';
              return (
                <li class:list={['series-item', { 'is-soon': !isLive }]}>
                  <Tag
                    {...(isLive ? { href: `/blog/${item.slug}/` } : {})}
                    class="series-card"
                  >
                    <span class="series-num">{String(item.num).padStart(2, '0')}</span>
                    <span class="series-body">
                      <span class="series-title">
                        {item.title}
                        {!isLive && <span class="pill soon-pill">coming soon</span>}
                      </span>
                      <span class="series-blurb">{item.blurb}</span>
                    </span>
                    {isLive && <span class="series-arrow" aria-hidden="true">→</span>}
                  </Tag>
                </li>
              );
            })}
        </ol>
      </section>
    ))
  }
</div>

<style>
  .series-group { margin-bottom: 2.5rem; }
  .series-section {
    margin: 0 0 0.9rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--sun-deep);
    font-family: var(--font-body);
    font-weight: 600;
  }
  .series-items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }
  .series-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.15rem;
    background: var(--paper-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  a.series-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
    border-color: var(--sun);
  }
  .is-soon .series-card {
    opacity: 0.72;
    cursor: default;
  }
  .series-num {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--sun);
    min-width: 2ch;
    line-height: 1.2;
  }
  .series-body { display: block; }
  .series-title {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.12rem;
    line-height: 1.25;
    margin-bottom: 0.25rem;
  }
  .series-blurb {
    display: block;
    font-size: 0.92rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  .soon-pill { margin-left: 0.5rem; vertical-align: middle; }
  .series-arrow {
    margin-left: auto;
    align-self: center;
    color: var(--sun);
    font-size: 1.2rem;
    transition: transform 0.15s ease;
  }
  a.series-card:hover .series-arrow { transform: translateX(3px); }
</style>
