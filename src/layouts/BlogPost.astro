---
import BaseLayout from './BaseLayout.astro';
import { SERIES_FLAT } from '../series';
import { slugify } from '../utils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  heroAlt?: string;
  category?: string;
  tags?: string[];
  slug: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroAlt,
  category,
  tags = [],
  slug,
} = Astro.props;

const idx = SERIES_FLAT.findIndex((p) => p.slug === slug);
const current = idx >= 0 ? SERIES_FLAT[idx] : undefined;
const prev = idx > 0 ? SERIES_FLAT[idx - 1] : undefined;
const next =
  idx >= 0 && idx < SERIES_FLAT.length - 1 ? SERIES_FLAT[idx + 1] : undefined;

const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="post-header wrap">
      <p class="eyebrow">
        {current ? `Part ${current.num} of 17` : 'From the series'}
      </p>
      <h1>{title}</h1>
      <p class="post-meta">
        <time datetime={pubDate.toISOString()}>{dateFmt(pubDate)}</time>
        {updatedDate && <span> · updated {dateFmt(updatedDate)}</span>}
      </p>
    </header>

    {
      heroImage && (
        <figure class="post-hero wrap-wide">
          <img src={heroImage} alt={heroAlt ?? ''} />
        </figure>
      )
    }

    <div class="post-body wrap">
      <slot />
    </div>

    {
      (category || tags.length > 0) && (
        <div class="post-taxonomy wrap">
          {category && (
            <a class="pill" href={`/categories/${slugify(category)}/`}>
              {category}
            </a>
          )}
          {tags.map((t) => (
            <a class="tag-chip" href={`/tags/${slugify(t)}/`}>
              #{t}
            </a>
          ))}
        </div>
      )
    }

    <nav class="post-nav wrap">
      {
        prev ? (
          <a class="post-nav-link prev" href={`/blog/${prev.slug}/`}>
            <span class="dir">← Previous</span>
            <span class="t">{prev.title}</span>
          </a>
        ) : (
          <span />
        )
      }
      {
        next ? (
          <a class="post-nav-link next" href={`/blog/${next.slug}/`}>
            <span class="dir">Next →</span>
            <span class="t">{next.title}</span>
          </a>
        ) : (
          <a class="post-nav-link next" href="/#series">
            <span class="dir">Back to the series →</span>
            <span class="t">See all posts</span>
          </a>
        )
      }
    </nav>

    <p class="back-all wrap">
      <a href="/#series">↑ All {17} posts in the series</a>
    </p>
  </article>

  <style>
    .post-header {
      padding-top: 3rem;
      text-align: center;
    }
    .post-header h1 { margin: 0.4rem 0 0.5rem; }
    .post-meta { color: var(--ink-faint); font-size: 0.92rem; }

    .post-hero {
      margin: 2rem auto 0;
    }
    .post-hero img {
      width: 100%;
      box-shadow: var(--shadow);
    }
    .post-hero figcaption {
      text-align: center;
      color: var(--ink-faint);
      font-size: 0.85rem;
      margin-top: 0.6rem;
    }

    .post-body {
      margin-top: 2.5rem;
      font-size: 1.1rem;
    }
    .post-body :global(p) { margin: 1.3em 0; }
    .post-body :global(h2) { scroll-margin-top: 5rem; }
    .post-body :global(img) {
      display: block;
      margin: 2rem auto;
      box-shadow: var(--shadow);
    }
    /* screenshot placeholders the author fills in later */
    .post-body :global(.shot) {
      display: block;
      margin: 2rem 0;
      padding: 2rem 1.25rem;
      border: 2px dashed var(--line);
      border-radius: var(--radius);
      background: rgba(255, 253, 248, 0.6);
      color: var(--ink-faint);
      font-size: 0.9rem;
      text-align: center;
    }

    .post-taxonomy {
      margin-top: 2.5rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
    }
    .post-taxonomy .pill { text-decoration: none; }
    .post-taxonomy .tag-chip {
      font-size: 0.85rem;
      color: var(--ink-faint);
      text-decoration: none;
      padding: 0.3rem 0.5rem;
      border-radius: 999px;
    }
    .post-taxonomy .tag-chip:hover { color: var(--ember); }

    .post-nav {
      margin-top: 3.5rem;
      display: flex;
      gap: 1rem;
      justify-content: space-between;
    }
    .post-nav-link {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      padding: 0.9rem 1.15rem;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--paper-raised);
      text-decoration: none;
      max-width: 48%;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .post-nav-link:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
    .post-nav-link.next { text-align: right; margin-left: auto; }
    .post-nav-link .dir { font-size: 0.78rem; color: var(--sun-deep); font-weight: 600; }
    .post-nav-link .t { font-family: var(--font-display); font-weight: 600; color: var(--ink); }

    .back-all { margin-top: 2rem; text-align: center; font-size: 0.95rem; }
  </style>
</BaseLayout>
